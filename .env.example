# =============================================================================
# AI Payment Fraud Investigator - Environment Configuration Template
# Copy this file to ".env" and supply your own values. Never commit ".env".
# =============================================================================

# ---------------------------------------------------------------------------
# LLM provider configuration (optional).
# If left unset, the system runs in deterministic rule-based mode and requires
# no external model. Set these values to enable AI-generated narratives.
# Supported providers: "openai", "azure_openai", "none"
# ---------------------------------------------------------------------------
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_API_BASE=
LLM_API_VERSION=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Investigation engine thresholds (0-100 risk scale).
# ---------------------------------------------------------------------------
RISK_DECLINE_THRESHOLD=75
RISK_ESCALATE_THRESHOLD=45

# ---------------------------------------------------------------------------
# Runtime behavior.
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
OUTPUT_DIR=output
